AI_PROVIDER=gemini
AI_PIPELINE_MODE=one_call
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.0-flash-lite,gemini-2.0-flash

