AI_PROVIDER=gemini
AI_PIPELINE_MODE=multi
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash-lite,gemini-2.0-flash
FINAL_MODEL=gemini-2.0-flash
FINAL_DIRECTOR_MODEL=gemini-2.5-pro
FINAL_DIRECTOR_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash
FINAL_LOCAL_PROVIDER=ollama
FINAL_LOCAL_MODEL=qwen3:14b

# Hybrid local/cloud prompt company:
# PM / Planning: local qwen3
# MIKE_PROVIDER=ollama
# MIKE_MODEL=qwen3:14b
# Structure / UX: local gemma
# MINA_PROVIDER=ollama
# MINA_MODEL=gemma4:latest
# Scope: local qwen3
# NORA_PROVIDER=ollama
# NORA_MODEL=qwen3:14b
# Dev / Implementation plan: local qwen coder
# JAY_PROVIDER=ollama
# JAY_MODEL=freehuntx/qwen3-coder:14b
# DX helper: local qwen coder
# DANA_PROVIDER=ollama
# DANA_MODEL=freehuntx/qwen3-coder:14b
